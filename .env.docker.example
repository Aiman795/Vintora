# Copy this file to .env before running docker compose.

# Public frontend port on your machine/server
FRONTEND_PORT=80

# Use local Docker Mongo by default. For Atlas, replace with your Atlas URI.
MONGODB_URI=mongodb://mongo:27017/vintora

JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=http://localhost
ADMIN_INVITE_CODE=replace-admin-code

# Gmail app password credentials for email verification and notifications
EMAIL_USER=
EMAIL_PASS=

# Optional AI keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Keep false for reliable local demo fallback. Set true only if external IDM-VTON access works.
USE_EXTERNAL_TRYON=false

